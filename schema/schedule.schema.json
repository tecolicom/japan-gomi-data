{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/tecolicom/japan-gomi-data/main/schema/schedule.schema.json",
  "title": "ごみ収集コース日程",
  "type": "object",
  "required": [
    "metadata",
    "rules"
  ],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "city",
        "course",
        "year",
        "source"
      ],
      "additionalProperties": false,
      "properties": {
        "city": {
          "type": "string",
          "minLength": 1
        },
        "course": {
          "type": "string",
          "minLength": 1
        },
        "course_name_ja": {
          "type": "string"
        },
        "areas": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name"
            ],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "yomi": {
                "type": "string",
                "minLength": 1
              },
              "note": {
                "type": "string",
                "minLength": 1
              },
              "machiaza_id": {
                "type": "string",
                "pattern": "^[0-9]{6}-[0-9]{7}$",
                "description": "アドレス・ベース・レジストリの町字ID (lg_code 6桁-machiaza_id 7桁)。町字レベルの正規キー"
              }
            }
          }
        },
        "year": {
          "type": "integer"
        },
        "fiscal_year_ja": {
          "type": "string"
        },
        "source": {
          "type": "object",
          "required": [
            "extracted_at"
          ],
          "additionalProperties": false,
          "properties": {
            "pdf_url": {
              "type": "string",
              "format": "uri"
            },
            "cover_pdf_url": {
              "type": "string",
              "format": "uri"
            },
            "source_url": {
              "type": "string",
              "format": "uri"
            },
            "extracted_at": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "extracted_by": {
              "type": "string"
            },
            "verified_by": {
              "type": "string"
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "category",
          "pattern"
        ],
        "additionalProperties": false,
        "properties": {
          "category": {
            "type": "string",
            "minLength": 1
          },
          "pattern": {
            "enum": [
              "weekly",
              "monthly_nth",
              "monthly_specific"
            ]
          },
          "days": {
            "type": "array",
            "items": {
              "enum": [
                "MO",
                "TU",
                "WE",
                "TH",
                "FR",
                "SA",
                "SU"
              ]
            }
          },
          "occurrences": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            }
          },
          "dates": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            }
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "date"
        ],
        "additionalProperties": false,
        "properties": {
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "category": {
            "type": [
              "string",
              "null"
            ]
          },
          "cancelled": {
            "type": "boolean"
          },
          "note": {
            "type": "string"
          }
        }
      }
    }
  }
}
