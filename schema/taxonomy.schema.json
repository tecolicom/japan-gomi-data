{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/tecolicom/japan-gomi-data/main/schema/taxonomy.schema.json",
  "title": "自治体別ごみ種別 taxonomy",
  "type": "object",
  "required": ["categories"],
  "additionalProperties": false,
  "properties": {
    "categories": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "overrides": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string" },
          "short": { "type": "string" },
          "color": { "type": "string" }
        }
      }
    }
  }
}
