{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/tecolicom/japan-gomi-data/main/schema/taxonomy.schema.json",
  "title": "自治体別ごみ種別 taxonomy",
  "type": "object",
  "required": [
    "categories"
  ],
  "additionalProperties": false,
  "properties": {
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "overrides": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "label": {
            "type": "string"
          },
          "short": {
            "type": "string"
          },
          "color": {
            "type": "string"
          }
        }
      }
    },
    "groups": {
      "type": "array",
      "description": "参考情報: 自治体が同日一括回収に付けている括り名 (「資源ごみ」「資源化物」等)。members は categories の部分集合。セマンティクス: あるコースで members 全カテゴリの規則 (pattern/days/occurrences/dates) が完全一致する場合に限り、そのコースでこの括り名が適用可能 — 個別日程の物件 (荒川の一部) や別体系の地区 (倉敷・真備) では不一致となり適用されない。消費側はコース単位で判定する (無視してもよい)",
      "items": {
        "type": "object",
        "required": [
          "label",
          "members"
        ],
        "additionalProperties": false,
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "short": {
            "type": "string"
          },
          "members": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "note": {
            "type": "string"
          }
        }
      }
    }
  }
}
